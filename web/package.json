{
  "name": "memo-web-frontend",
  "version": "1.0.0",
  "description": "Vanilla JavaScript web frontend for Memo App",
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest tests/unit",
    "test:property": "NODE_OPTIONS='--experimental-vm-modules' jest tests/property",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint js/**/*.js tests/**/*.js",
    "lint:fix": "eslint js/**/*.js tests/**/*.js --fix",
    "serve": "npx serve ."
  },
  "keywords": [
    "todo",
    "vanilla-js",
    "frontend"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^24.0.0",
    "node-fetch": "^3.3.2"
  }
}
